{
  "name": "wechat-opencode-bot",
  "version": "1.0.0",
  "description": "Connect WeChat to OpenCode - chat with OpenCode from WeChat",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "postinstall": "npm run build",
    "start": "node dist/main.js",
    "run": "node dist/main.js start",
    "dev": "tsc --watch",
    "test": "node --test dist/tests/*.test.js",
    "setup": "node dist/main.js setup",
    "daemon": "bash scripts/daemon.sh"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.0.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/qrcode-terminal": "^0.12.0",
    "typescript": "^5.7.0"
  },
  "keywords": ["wechat", "opencode", "bot", "chat"],
  "author": "",
  "license": "MIT"
}